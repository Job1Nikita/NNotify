<Window x:Class="NNotify.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:NNotify.Localization"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="NNotify"
        Height="680"
        Width="1040"
        MinHeight="560"
        MinWidth="920"
        WindowStyle="None"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <DataTemplate x:Key="PriorityBadgeTemplate">
            <Border Padding="9,3" CornerRadius="10" HorizontalAlignment="Left">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource PriorityP1BadgeBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Priority}" Value="0">
                                <Setter Property="Background" Value="{DynamicResource PriorityP0BadgeBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Priority}" Value="2">
                                <Setter Property="Background" Value="{DynamicResource PriorityP2BadgeBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding PriorityLabel}"
                           FontWeight="Bold"
                           FontSize="12"
                           Foreground="{DynamicResource BadgeTextBrush}" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="StatusBadgeTemplate">
            <Border Padding="9,3" CornerRadius="10" HorizontalAlignment="Left">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource StatusDefaultBadgeBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="acked">
                                <Setter Property="Background" Value="{DynamicResource StatusAckBadgeBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="missed">
                                <Setter Property="Background" Value="{DynamicResource StatusMissedBadgeBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="fired">
                                <Setter Property="Background" Value="{DynamicResource StatusFiredBadgeBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding StatusLabel}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Foreground="{DynamicResource BadgeTextBrush}" />
            </Border>
        </DataTemplate>

        <Style x:Key="RightAnchoredHeaderStyle" TargetType="GridViewColumnHeader" BasedOn="{StaticResource {x:Type GridViewColumnHeader}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                        <Border x:Name="HeaderBorder"
                                Margin="{TemplateBinding Margin}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter RecognizesAccessKey="True"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource ListHeaderHoverBrush}" />
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="Role" Value="Padding">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="Transparent" />
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="Transparent" />
                                <Setter TargetName="HeaderBorder" Property="BorderThickness" Value="0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid Background="{DynamicResource MainBackgroundBrush}"
          PreviewMouseLeftButtonDown="OnRootPreviewMouseLeftButtonDown">
        <Ellipse Width="300" Height="300" Fill="#45A4D8FF" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-80,-120,0,0" IsHitTestVisible="False" />
        <Ellipse Width="340" Height="340" Fill="#30B5FFD9" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-80,-140" IsHitTestVisible="False" />

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="TitleBarCard" Style="{StaticResource PanelCardStyle}" Padding="10,7">
                <Grid MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="30" Height="30" CornerRadius="9" Background="{DynamicResource AccentGradientBrush}" ClipToBounds="True" VerticalAlignment="Center">
                            <Grid>
                                <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="White" Data="M4,20 V4 H8 L16,12 V4 H20 V20 H16 L8,12 V20 Z" />
                                    </Canvas>
                                </Viewbox>
                                <Ellipse Width="5"
                                         Height="5"
                                         Fill="#8EEBFF"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Margin="0,4,4,0" />
                            </Grid>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="NNotify" FontSize="17" FontWeight="Bold" Margin="0" />
                            <TextBlock Text="{loc:Loc MainTagline}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource TitleBarButtonStyle}" Content="&#xE921;" Click="OnMinimizeClick" shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                        <Button Style="{StaticResource TitleBarButtonStyle}" Click="OnMaximizeRestoreClick" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock x:Name="MaxRestoreGlyph" Text="&#xE922;" Margin="0" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                        </Button>
                        <Button Style="{StaticResource TitleBarCloseButtonStyle}" Content="&#xE8BB;" Click="OnCloseButtonClick" shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="212" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="HeaderCard" Grid.Row="0" Style="{StaticResource PanelCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="{loc:Loc MainButtonAdd}" Width="116" Style="{StaticResource AccentButtonStyle}" Click="OnAddClick" />
                            <Button Content="{loc:Loc CommonRefresh}" Width="104" Click="OnRefreshClick" />
                            <Button Content="{loc:Loc CommonSettings}" Width="108" Click="OnSettingsClick" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox x:Name="TopmostCheckBox" Content="{loc:Loc MainAlwaysOnTop}" VerticalAlignment="Center" Click="OnTopmostToggle" Margin="12,4,4,4" />
                            <CheckBox x:Name="DarkThemeCheckBox" Content="{loc:Loc MainDarkTheme}" VerticalAlignment="Center" Click="OnThemeToggle" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.65*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="UpcomingCard" Grid.Column="0" Style="{StaticResource PanelCardStyle}" Margin="0,0,8,0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="{loc:Loc MainUpcomingTitle}" FontSize="16" FontWeight="SemiBold" Margin="2,0,2,0" />
                                <TextBlock Text="{loc:Loc MainUpcomingSubtitle}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="2,0,2,0" />
                            </StackPanel>

                            <ListView x:Name="UpcomingListView"
                                      MouseDoubleClick="OnUpcomingMouseDoubleClick">
                                <ListView.ContextMenu>
                                    <ContextMenu Style="{StaticResource AppContextMenuStyle}">
                                        <MenuItem Header="{loc:Loc CommonEdit}"
                                                  Style="{StaticResource AppMenuItemStyle}"
                                                  Click="OnUpcomingContextEditClick" />
                                        <MenuItem Header="{loc:Loc CommonDelete}"
                                                  Style="{StaticResource AppMenuItemStyle}"
                                                  Click="OnUpcomingContextDeleteClick" />
                                    </ContextMenu>
                                </ListView.ContextMenu>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{loc:Loc MainColumnDue}" Width="166" DisplayMemberBinding="{Binding EffectiveDueLocal, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />
                                        <GridViewColumn Header="{loc:Loc MainColumnPriority}" Width="94" CellTemplate="{StaticResource PriorityBadgeTemplate}" />
                                        <GridViewColumn Header="{loc:Loc MainColumnText}" Width="300" DisplayMemberBinding="{Binding Title}" />
                                        <GridViewColumn Header="{loc:Loc MainColumnStatus}" Width="138" CellTemplate="{StaticResource StatusBadgeTemplate}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </Border>

                    <Border x:Name="MissedCard" Grid.Column="1" Style="{StaticResource PanelCardStyle}" Margin="8,0,0,0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="{loc:Loc MainMissedTitle}" FontSize="16" FontWeight="SemiBold" Margin="2,0,2,0" />
                                <TextBlock Text="{loc:Loc MainMissedSubtitle}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="2,0,2,0" TextWrapping="Wrap" />
                            </StackPanel>

                            <ListView x:Name="MissedListView">
                                <ListView.ContextMenu>
                                    <ContextMenu Style="{StaticResource AppContextMenuStyle}">
                                        <MenuItem Header="{loc:Loc CommonDelete}"
                                                  Style="{StaticResource AppMenuItemStyle}"
                                                  Click="OnMissedContextDeleteClick" />
                                    </ContextMenu>
                                </ListView.ContextMenu>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{loc:Loc MainColumnDue}" Width="156" DisplayMemberBinding="{Binding EffectiveDueLocal, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />
                                        <GridViewColumn Header="{loc:Loc MainColumnPriority}" Width="98" CellTemplate="{StaticResource PriorityBadgeTemplate}" />
                                        <GridViewColumn Header="{loc:Loc MainColumnText}" Width="255" DisplayMemberBinding="{Binding Title}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </Border>
                </Grid>

                <Border x:Name="HistoryCard" Grid.Row="2" Style="{StaticResource PanelCardStyle}" Margin="0,12,0,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="{loc:Loc MainHistoryTitle}" FontSize="16" FontWeight="SemiBold" Margin="2,0,2,0" />
                            <TextBlock Text="{loc:Loc MainHistorySubtitle}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="2,0,2,0" />
                        </StackPanel>

                        <ListView x:Name="HistoryListView">
                            <ListView.ContextMenu>
                                <ContextMenu Style="{StaticResource AppContextMenuStyle}">
                                    <MenuItem Header="{loc:Loc MainMenuRepeat}"
                                              Style="{StaticResource AppMenuItemStyle}"
                                              Click="OnHistoryContextRepeatClick" />
                                    <MenuItem Header="{loc:Loc CommonDelete}"
                                              Style="{StaticResource AppMenuItemStyle}"
                                              Click="OnHistoryContextDeleteClick" />
                                </ContextMenu>
                            </ListView.ContextMenu>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{loc:Loc MainColumnWhen}" Width="168" DisplayMemberBinding="{Binding HistoryMomentLocal, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />
                                    <GridViewColumn Header="{loc:Loc MainColumnPriority}" Width="98" CellTemplate="{StaticResource PriorityBadgeTemplate}" />
                                    <GridViewColumn Header="{loc:Loc MainColumnText}" Width="424" DisplayMemberBinding="{Binding Title}" />
                                    <GridViewColumn Header="{loc:Loc MainColumnResult}" Width="140" CellTemplate="{StaticResource StatusBadgeTemplate}" />
                                    <GridViewColumn Header="{loc:Loc MainColumnEscalation}" Width="160" DisplayMemberBinding="{Binding EscalatedLocalText}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </Border>

                <Border x:Name="FooterCard" Grid.Row="3" Style="{StaticResource PanelCardStyle}" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{loc:Loc MainQuickActionsTitle}" FontSize="15" FontWeight="SemiBold" Margin="2,0,2,0" />
                            <TextBlock x:Name="HotKeyHintText"
                                       Text=""
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="2,0,2,0" />
                        </StackPanel>

                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel x:Name="UpcomingActionsPanel"
                                        Orientation="Horizontal"
                                        Visibility="Collapsed">
                                <Button Content="{loc:Loc ActionAck}" Width="122" Click="OnAckClick" />
                                <Button Content="{loc:Loc ActionSnooze5}" Width="122" Click="OnSnooze5Click" />
                                <Button Content="{loc:Loc ActionSnooze15}" Width="126" Click="OnSnooze15Click" />
                                <Button Content="{loc:Loc ActionEdit}" Width="102" Click="OnEditClick" />
                                <Button Content="{loc:Loc CommonDelete}" Width="102" Click="OnDeleteClick" ToolTip="{loc:Loc MainDeleteTooltip}" />
                            </StackPanel>

                            <StackPanel x:Name="DeleteOnlyActionsPanel"
                                        Orientation="Horizontal"
                                        Visibility="Collapsed">
                                <Button Content="{loc:Loc CommonDelete}" Width="102" Click="OnDeleteClick" ToolTip="{loc:Loc MainDeleteTooltip}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
