<Window x:Class="NNotify.Windows.ConfirmDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:NNotify.Localization"
        Title="{loc:Loc ConfirmDefaultTitle}"
        Height="250"
        Width="460"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <LinearGradientBrush x:Key="DangerGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF6363" Offset="0" />
            <GradientStop Color="#E24444" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="DangerGradientHoverBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF7B7B" Offset="0" />
            <GradientStop Color="#F05252" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource DangerGradientBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#D33A3A" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource DangerGradientHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border Style="{StaticResource PanelCardStyle}" Margin="16" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="12,10,12,6" Background="Transparent" MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="24" Height="24" CornerRadius="7" Background="{DynamicResource AccentGradientBrush}" ClipToBounds="True" VerticalAlignment="Center">
                            <Grid>
                                <Viewbox Width="13" Height="13" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="White" Data="M4,20 V4 H8 L16,12 V4 H20 V20 H16 L8,12 V20 Z" />
                                    </Canvas>
                                </Viewbox>
                                <Ellipse Width="4"
                                         Height="4"
                                         Fill="#8EEBFF"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Margin="0,3,3,0" />
                            </Grid>
                        </Border>
                        <TextBlock x:Name="WindowTitleText" Margin="8,0,0,0" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource TitleBarCloseButtonStyle}"
                            Content="&#xE8BB;"
                            Click="OnCloseButtonClick" />
                </Grid>

                <Grid Grid.Row="1" Margin="16,8,16,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="QuestionTitleText"
                               Grid.Row="0"
                               Text="{loc:Loc ConfirmDefaultQuestionTitle}"
                               FontSize="28"
                               FontWeight="Bold"
                               Margin="0,0,0,8" />

                    <TextBlock x:Name="QuestionMessageText"
                               Grid.Row="1"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Margin="0,0,0,8" />

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button x:Name="CancelButton"
                                Content="{loc:Loc CommonCancel}"
                                Width="108"
                                IsCancel="True"
                                Click="OnCancelClick" />
                        <Button x:Name="ConfirmButton"
                                Width="118"
                                Style="{StaticResource DangerButtonStyle}"
                                Click="OnConfirmClick" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
