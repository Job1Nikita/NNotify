# Server bind
HOST=0.0.0.0
PORT=5334

# PostgreSQL connection string
DATABASE_URL=postgres://nnotify:change_me@127.0.0.1:5432/nnotify

# JWT / token secrets
JWT_ACCESS_SECRET=change_me_super_long_random_string
REFRESH_TOKEN_PEPPER=change_me_super_long_random_string
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# TLS (required unless ALLOW_HTTP=1)
TLS_CERT_PATH=/etc/nnotify/certs/fullchain.pem
TLS_KEY_PATH=/etc/nnotify/certs/privkey.pem
ALLOW_HTTP=0

# Optional notification to admin chat on new registration
ADMIN_TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=

# CORS
ALLOWED_ORIGIN=